{
  "mcpServers": {
    "Context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {},
      "directTools": true
    },
    "angular-cli": {
      "command": "npx",
      "args": [
        "-y",
        "@angular/cli",
        "mcp"
      ],
      "directTools": true
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--viewport",
        "1280x720",
        "--no-usage-statistics"
      ],
      "lifecycle": "lazy"
    }
  },
  "imports": [
    "cursor",
    "claude-code"
  ]
}
